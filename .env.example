# Vercel Postgres Database Configuration
# These environment variables will be automatically set when you connect
# Vercel Postgres to your project. For local development, you can use
# the values from your Vercel Postgres dashboard.

# Primary connection string (automatically set by Vercel)
POSTGRES_URL="postgres://default:password@ep-cool-breeze-123456.us-east-1.postgres.vercel-storage.com:5432/verceldb"

# Alternative connection strings (automatically set by Vercel)
POSTGRES_PRISMA_URL="postgres://default:password@ep-cool-breeze-123456.us-east-1.postgres.vercel-storage.com:5432/verceldb?pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NON_POOLING="postgres://default:password@ep-cool-breeze-123456.us-east-1.postgres.vercel-storage.com:5432/verceldb"
POSTGRES_USER="default"
POSTGRES_HOST="ep-cool-breeze-123456.us-east-1.postgres.vercel-storage.com"
POSTGRES_PASSWORD="your_password_here"
POSTGRES_DATABASE="verceldb"

# Application Settings
NODE_ENV="development"
# Set to "production" when deploying

# Security (optional)
# JWT_SECRET="your_jwt_secret_key_here_for_production"
# SESSION_SECRET="your_session_secret_here"

# Email Service (for verification emails - optional)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# EMAIL_FROM="noreply@decentraforce.com"

# Frontend URL
FRONTEND_URL="http://localhost:3000"

# How to use:
# 1. Copy this file to .env.local for local development
# 2. Fill in your actual values
# 3. For production on Vercel, add these variables in the Vercel dashboard
#    under Project Settings > Environment Variables
# 4. Never commit .env.local to version control